---
interface Props {
  title: string;
  reference: string;
  text?: string;
}

const { title, reference, text } = Astro.props as Props;

const encodeReference = encodeURIComponent(reference);
const url = `https://philasdb-bible.fly.dev/passage?search=${encodeReference}`;
---

<div class="scripture">
  <b>{title}:</b>
  <a href={url} target="_blank">{reference}</a>
  {text && <em>{text}</em>}
</div>
